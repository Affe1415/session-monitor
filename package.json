{
  "name": "session-monitor",
  "version": "1.0.0",
  "description": "Professional Trading Session Monitor",
  "main": "dist-electron/main.js",
  "author": "Session Monitor",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && set VITE_DEV_SERVER_URL=http://localhost:5173&& electron .\"",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win nsis portable msi",
    "portable": "npm run build && electron-builder --win portable",
    "release": "npm run build && electron-builder --win nsis portable msi --publish always"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "luxon": "^3.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.sessionmonitor.app",
    "productName": "Session Monitor",
    "copyright": "Copyright (c) 2026 Session Monitor",
    "artifactName": "${productName}${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Affe1415",
        "repo": "session-monitor"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "publisherName": "Session Monitor",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "SessionMonitorSetup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Session Monitor",
      "runAfterFinish": true,
      "perMachine": false,
      "allowElevation": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "SessionMonitorPortable.exe"
    },
    "msi": {
      "artifactName": "SessionMonitor.msi",
      "warningsAsErrors": false,
      "additionalLightArgs": [
        "-sval"
      ]
    }
  }
}
